{
    "name": "ImageNet_LT_ResNeXt50_SADE",
    "n_gpu": 2,

    "arch": {
        "type": "PaCo_TADE",
        "args": {
            "num_classes": 1000,
            "num_experts": 3,
            "K": 8192,
            "mlp": true
        }
    },
    "data_loader": {
        "type": "ImageNetLTDataLoader",
        "args":{
            "data_dir": "/scratch/ktan24/documents/SAGE_dataset/imagenet",
            "batch_size": 64,
            "shuffle": true,
            "drop_last": true,
            "num_workers": 12
        }
    },
    "optimizer": {
        "type": "SGD",
        "args":{
            "lr": 0.025,
            "weight_decay": 5e-4,
            "momentum": 0.9,
            "nesterov": true
        }
    },
    "add_extra_info": true,
    "loss": {
        "type": "MultiExpertPaCoLoss",
        "args":{
             "alpha": 0.05,
             "smooth": 0.1,
             "K": 8192
        }
    },
    "metrics": [
        "accuracy"
    ],
    "lr_scheduler": {
        "type": "CosineAnnealingLR",
        "args": {
            "T_max": 180,
            "eta_min": 0
        }
    },
    "trainer": {
        "epochs": 180,
        "save_dir": "saved/imagenet/paco_e180_inv2_bs256_lr0.025",
        "save_period": 180,
        "verbosity": 2,
        "monitor": "max val_accuracy",
        "tensorboard": false
    }
}